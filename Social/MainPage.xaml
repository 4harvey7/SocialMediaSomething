<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Social.MainPage"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#121212}">

    <Grid RowDefinitions="Auto,*">

        <!-- ADD POST BUTTON -->
        <Button Text="Add Post"
                Margin="10"
                BackgroundColor="DodgerBlue"
                TextColor="White"
                Clicked="OnAddPostClicked"
                Grid.Row="0"/>

        <!-- FEED -->
        <CollectionView x:Name="PostsCollectionView"
                        Grid.Row="1">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Frame Margin="10"
                           Padding="15"
                           CornerRadius="15"
                           BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}"
                           HasShadow="True">

                        <!-- ✅ THIS MAKES IT CLICKABLE -->
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPostTapped"/>
                        </Frame.GestureRecognizers>

                        <VerticalStackLayout Spacing="8">

                            <Label Text="{Binding Name}"
                                   FontSize="18"
                                   FontAttributes="Bold"/>

                            <Image Source="{Binding Image}"
                                   HeightRequest="180"
                                   Aspect="AspectFill"/>

                            <Label Text="{Binding Description}"
                                   FontSize="14"
                                   MaxLines="2"/>

                            <Label Text="{Binding FormattedDate}"
                                   FontSize="10"
                                   TextColor="Gray"/>

                            <Label Text="{Binding VisibilityText}"
                                   FontSize="10"
                                   TextColor="Gray"/>

                        </VerticalStackLayout>

                    </Frame>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>